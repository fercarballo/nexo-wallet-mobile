# Plantilla de variables de entorno de nexo-wallet-mobile.
# Copiar a .env y completar. NUNCA subir el .env ni el APK al repositorio.
#
# Estas variables SOLO se usan en el modo real (-DwalletMode=appium). En modo simulado
# (por defecto) no hace falta ninguna.

# Servidor Appium en ejecución
NEXO_APPIUM_URL=http://127.0.0.1:4723

# Emulador o dispositivo objetivo
NEXO_DEVICE_NAME=Android Emulator
NEXO_PLATFORM_VERSION=14

# Ruta al APK de la app ficticia (no se versiona; ver .gitignore)
NEXO_APP=apps/nexo-wallet.apk

# Identidad de la app
NEXO_APP_PACKAGE=com.nexo.wallet
NEXO_APP_ACTIVITY=com.nexo.wallet.MainActivity
